  "keyFeatures": [
    "Interactive satellite map with drag-and-drop bay assignment",
    "Real-time traffic light monitoring system (green/yellow/red alerts)",
    "Floating dashboard panels showing priority units, shift counts, and average yard time",
    "Incident tracking and management with automatic alerts",
    "Role-based access control (Admin/Client)",
    "Supabase integration for real-time data synchronization",
    "n8n webhook automation for external integrations",
    "Dark mode UI optimized for operational visibility"
  ],
  "publicApiSurface": [
    "fetchCamionesCola() - Retrieve trucks in queue",
    "fetchUnidadPrioridad() - Get highest priority unit",
    "fetchDashboardTurnos() - Get shift counts",
    "fetchPromedioPatioNeto() - Get average yard time",
    "actualizarBahiaDirecto() - Update bay assignment",
    "marcarSalidaDirecto() - Mark truck departure",
    "abrirIncidencia() - Open new incident",
    "cerrarIncidencia() - Close open incident",
    "loginUsuario() - Authenticate user",
    "BAHIAS_CONFIG - Bay configuration mapping",
    "NOMBRES_TIPO_CAMION - Truck type definitions"
  ]
